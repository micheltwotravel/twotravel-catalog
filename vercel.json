{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/)(?!.*\\.html$).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/chat.js":         { "maxDuration": 60 },
    "api/apify.js":        { "maxDuration": 60 },
    "api/travefy-send.js": { "maxDuration": 60 },
    "api/agent.js":        { "maxDuration": 10 }
  }
}
